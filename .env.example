# Cloudflare Teams registration token。
# 推荐直接填完整的 com.cloudflare.warp://...auth?token=... 链接。
TEAMS_TOKEN=com.cloudflare.warp://your-team.cloudflareaccess.com/auth?token=replace-with-fresh-registration-token

# 宿主机监听地址与端口。
# 默认只绑定到本机；确认可用后再考虑是否改成 0.0.0.0 对外开放。
HOST_BIND_IP=127.0.0.1
HOST_BIND_PORT=1080

# 可选：手工覆盖 endpoint 候选池。
# 留空时使用项目内置候选池。
ENDPOINT_CANDIDATES=

# 其他参数保持默认即可。
# 日志、重试、启动探测、healthcheck 调优参数见 README。
