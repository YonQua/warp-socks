# Cloudflare Teams registration token。
# 推荐直接填完整的 com.cloudflare.warp://...auth?token=... 链接。
TEAMS_TOKEN=com.cloudflare.warp://your-team.cloudflareaccess.com/auth?token=replace-with-fresh-registration-token

# 宿主机监听地址与端口。默认只绑定到本机，先本机验证通过再决定是否对外开放。
# 127.0.0.1 -> 只有当前机器自己能连
# 0.0.0.0   -> 允许局域网或其他主机访问宿主机这个端口
# microsocks 是无认证 SOCKS5；只有在你明确知道风险时才改成 0.0.0.0。
HOST_BIND_IP=127.0.0.1
HOST_BIND_PORT=1080

# 启动阶段按顺序尝试 endpoint。
# 默认留空 -> 使用 Teams 返回的默认 endpoint
# 填一个值 -> 固定单 endpoint
# 填多个值 -> 逗号分隔的候选池，逐个测试轮换
ENDPOINT_CANDIDATES=
# 示例：
# ENDPOINT_CANDIDATES=162.159.193.5:2408,162.159.193.9:2408,162.159.193.8:2408

# Docker 重启策略。长期运行通常保持 unless-stopped。
RESTART_POLICY=unless-stopped

# 日志时间格式。默认固定东八区偏移，不依赖镜像额外安装 tzdata。
LOG_TIMEZONE=CST-8
LOG_TIME_FORMAT=%Y-%m-%d %H:%M:%S %Z

# microsocks 连接日志控制。
# 1 -> 输出连接日志；0 -> 使用 upstream -q 关闭连接日志。
MICROSOCKS_LOG_ACCESS=1
# 0 -> 默认隐藏本地 127.0.0.1 / ::1 探测流量，减少 healthcheck 刷屏
# 1 -> 一并输出本地探测流量，便于排障
MICROSOCKS_LOG_LOCAL_CLIENTS=0

# 想重建状态时，删除 ./wireguard/account.json 和 ./wireguard/wg0.conf 后重新启动。
