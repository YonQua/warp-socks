# 注册后端模式：
# auto      -> 自动按优先级选择：TEAMS_TOKEN > WARP_LICENSE_KEY > free
# teams     -> 强制走 Teams registration token
# wgcf-free -> 强制走免费 consumer WARP
# wgcf-plus -> 强制走 WARP+ license key
AUTH_MODE=auto

# Teams 模式使用的 registration token。
# 推荐直接填完整的 com.cloudflare.warp://...auth?token=... 链接。
# 在 AUTH_MODE=auto 时，如果这里有值，就会优先使用 teams。
TEAMS_TOKEN=com.cloudflare.warp://your-team.cloudflareaccess.com/auth?token=replace-with-fresh-registration-token

# WARP+ license key。
# 在 AUTH_MODE=auto 且没有 TEAMS_TOKEN 时，若这里有值，就走 wgcf-plus。
# 如果只想走免费模式，可留空。
WARP_LICENSE_KEY=

# 是否强制重新注册：
# 0 -> 默认，不清理已有状态
# 1 -> 清理已有状态并重新按当前后端注册
FORCE_REREGISTER=0

# 宿主机监听地址与端口。默认只开放给本机，先本机验证通过再决定是否对外开放。
# 127.0.0.1 -> 只有当前机器自己能连
# 0.0.0.0   -> 允许局域网或其他主机访问宿主机这个端口
# 如果你想让局域网其他设备访问，应改 HOST_BIND_IP，而不是改 BIND_PORT。
# 例如宿主机 LAN IP 是 10.10.10.4、HOST_BIND_PORT=1081 时，客户端应连接 socks5://10.10.10.4:1081。
# 强烈不建议随手改成 0.0.0.0。microsocks 是无认证 SOCKS5，改成对外监听后会直接暴露未鉴权代理。
# 只有在你已经有额外 ACL / 防火墙限制、且明确接受出口滥用风险时，才应考虑这样做。
HOST_BIND_IP=127.0.0.1
HOST_BIND_PORT=1080

# 容器内 socks5 监听地址与端口。一般保持默认即可。
# BIND_PORT 是容器内监听端口；宿主机端口冲突或想换对外端口时，应优先改 HOST_BIND_PORT。
BIND_ADDR=0.0.0.0
BIND_PORT=1080

# 隧道模式：
# ipv4  -> 只走 IPv4
# ipv6  -> 只走 IPv6
# dual  -> 双栈，当前默认推荐
WARP_STACK=dual

# 容器重启策略：
# unless-stopped -> 正常长期运行推荐
# no             -> 调试注册失败时推荐，避免一直重启刷日志
# 如果你启用了下面的 HEALTHCHECK_AUTO_RECOVER，自恢复也依赖这里不是 no。
RESTART_POLICY=unless-stopped

# 基础资源限制。
# 当前 compose.yaml 直接使用 mem_limit / cpus，让 docker compose up 就能生效。
MEM_LIMIT=256m
CPU_LIMIT=0.50

# 容器日志滚动限制，避免 json-file 日志无限增长。
LOG_MAX_SIZE=1m
LOG_MAX_FILE=1

# 健康检查连续失败后的轻量自恢复：
# 1 -> 连续失败达到阈值后，终止 PID 1，交给 Docker 重启容器并重建隧道
# 0 -> 仅标记 unhealthy，不自动恢复
HEALTHCHECK_AUTO_RECOVER=1

# 连续失败多少次后触发一次容器重启。
HEALTHCHECK_AUTO_RECOVER_THRESHOLD=3

# 注册失败后的重试次数与等待秒数。
# token 时效很短，恢复服务时建议把重试降到 1，避免 1015 / token 过期叠加。
REGISTER_RETRIES=1
REGISTER_RETRY_DELAY=5

# 启动阶段的出口探测。
# `wg-quick up` 只代表接口和路由已配置，不等于隧道已经可用。
# 这里会在启动 microsocks 之前先探测公网出口；如果连续失败，就直接退出容器，交给 Docker 按重启策略重试。
STARTUP_EGRESS_PROBE_RETRIES=3
STARTUP_EGRESS_PROBE_DELAY=2
STARTUP_EGRESS_PROBE_TIMEOUT=5

# 注册 API 的兼容客户端标识。
# 这是当前项目实测可用的兼容值，不等同于 Cloudflare 官方桌面客户端发布版本号。
CF_CLIENT_VERSION=a-6.10-2158

# 可选：手动覆盖 endpoint。
# 正常情况下建议留空，直接使用注册返回的 endpoint。
# 如果默认返回的 endpoint 握手失败，可改成你当前环境里验证过的固定端点。
# ENDPOINT_IP 适合“先拿一个固定端点跑起来”的场景。
# 当前环境 2026-03-27 实测时，`162.159.193.5:2408` 是更稳的样本之一；
# 但这类 endpoint 会随网络条件波动，下面的值只适合作为排障起点，不应视为长期固定事实。
# ENDPOINT_IP=engage.cloudflareclient.com:2408
# ENDPOINT_IP=162.159.193.7:2408

# 可选：多个 endpoint 候选，逗号分隔。
# 如果这里有值，启动阶段会按这里写的顺序逐个尝试。
# 运行中连续健康检查失败后，容器会重启，并重新按这里的顺序再尝试一轮。
# 如果同时设置了 ENDPOINT_IP，它会作为第一个候选，优先于这里的列表。
# 当前环境 2026-03-27 的一个较稳起点是：
# 162.159.193.5:2408,162.159.193.9:2408,162.159.193.8:2408,162.159.193.3:2408
# ENDPOINT_CANDIDATES=
ENDPOINT_CANDIDATES=162.159.193.5:2408,162.159.193.9:2408,162.159.193.8:2408,162.159.193.3:2408,162.159.193.7:2408
# SOCKS_USER=admin
# SOCKS_PASS=change-me